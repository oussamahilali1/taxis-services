# Backend runtime
NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/taxis_services?schema=public

# Frontend origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Admin session cookie
COOKIE_NAME=taxi_admin_session
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
ADMIN_SESSION_ABSOLUTE_TTL_MS=12h
ADMIN_SESSION_IDLE_TTL_MS=2h
ADMIN_SESSION_TOUCH_AFTER_MS=5m

# Abuse protection
PUBLIC_RATE_LIMIT_WINDOW_MS=15m
PUBLIC_RATE_LIMIT_MAX=10
PUBLIC_FINGERPRINT_RATE_LIMIT_MAX=6
ADMIN_RATE_LIMIT_WINDOW_MS=15m
ADMIN_IP_RATE_LIMIT_MAX=8
ADMIN_PRINCIPAL_RATE_LIMIT_MAX=5
PUBLIC_DUPLICATE_WINDOW_MS=10m
PUBLIC_CAPTCHA_MODE=off
PUBLIC_CAPTCHA_PROVIDER=
PUBLIC_CAPTCHA_SECRET=

# Initial admin bootstrap
SEED_ADMIN_EMAIL=admin@taxis-services.be
BOOTSTRAP_ADMIN_PASSWORD=
ALLOW_ADMIN_PASSWORD_RESET=false
